{
  "manifest_version": 3,
  "name": "Axure Scale Screen",
  "description": "Make Axure documents easier to zoom in Safari with slider and shortcuts.",
  "version": "0.2.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "optional_permissions": ["bookmarks"],
  "host_permissions": ["http://*/*", "https://*/*", "file://*/*"],
  "action": {
    "default_title": "Axure Scale",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "zoom-in": {
      "description": "放大 Axure 內容",
      "suggested_key": { "default": "Ctrl+Shift+Up", "mac": "Command+Shift+Up" }
    },
    "zoom-out": {
      "description": "縮小 Axure 內容",
      "suggested_key": { "default": "Ctrl+Shift+Down", "mac": "Command+Shift+Down" }
    },
    "zoom-reset": {
      "description": "重置 Axure 縮放",
      "suggested_key": { "default": "Ctrl+Shift+0", "mac": "Command+Shift+0" }
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file://*/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
