{
  "manifest_version": 3,
  "name": "Axure Scale Screen",
  "description": "Make Axure documents easier to zoom in Safari with slider and shortcuts.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_title": "Axure Scale",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
